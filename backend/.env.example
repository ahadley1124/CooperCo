# Leave the SurrealDB credentials unset to use the built-in file-backed database.
# Populate all of these values to connect to an external SurrealDB instance.
SURREALDB_URL=ws://127.0.0.1:8000/rpc
SURREALDB_NAMESPACE=cooperco
SURREALDB_DATABASE=app
SURREALDB_PATH=.surrealdb
# SURREALDB_USERNAME=root
# SURREALDB_PASSWORD=root
ROCKET_ADDRESS=127.0.0.1
ROCKET_PORT=9001
# Rocket serves the compiled frontend from frontend/dist by default when run
# from the workspace root, or ../frontend/dist when run from backend/.
# Override only if your deployment puts the Trunk build somewhere else.
# COOPERCO_STATIC_DIR=frontend/dist

# Microsoft Entra admin login.
# Local redirect URI must be registered exactly in the Entra app registration.
# When using trunk serve, /auth/* is proxied from 9000 to the Rocket backend.
MICROSOFT_CLIENT_ID=
# Optional for public-client PKCE flows; set for a confidential web app.
# MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
BACKEND_BASE_URL=http://127.0.0.1:9000
PUBLIC_APP_URL=http://127.0.0.1:9000
MICROSOFT_REDIRECT_URI=http://127.0.0.1:9000/auth/microsoft/callback
MICROSOFT_POST_LOGIN_REDIRECT_URI=http://127.0.0.1:9000/admin
ADMIN_ALLOWED_EMAILS=admin@example.com

# Production cookie/proxy settings.
# COOKIE_SECURE defaults to true when PUBLIC_APP_URL starts with https://.
# For Cloudflare Tunnel production, point the tunnel directly at Rocket:
#   beta.cooper-and-co.com -> http://127.0.0.1:9001
# PUBLIC_APP_URL=https://beta.cooper-and-co.com
# BACKEND_BASE_URL=https://beta.cooper-and-co.com
# MICROSOFT_REDIRECT_URI=https://beta.cooper-and-co.com/auth/microsoft/callback
# MICROSOFT_POST_LOGIN_REDIRECT_URI=https://beta.cooper-and-co.com/admin
# BEHIND_PROXY=true
# COOKIE_SECURE=true
# COOKIE_DOMAIN=beta.cooper-and-co.com
# PUBLIC_SITE_URLS=https://beta.cooper-and-co.com,https://cooper-and-co.com
# Required in production so encrypted private cookies survive restarts.
# Generate with: openssl rand -base64 32
# ROCKET_SECRET_KEY=
