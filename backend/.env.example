# Leave the SurrealDB credentials unset to use the built-in file-backed database.
# Populate all of these values to connect to an external SurrealDB instance.
SURREALDB_URL=ws://127.0.0.1:8000/rpc
SURREALDB_NAMESPACE=cooperco
SURREALDB_DATABASE=app
SURREALDB_PATH=.surrealdb
# SURREALDB_USERNAME=root
# SURREALDB_PASSWORD=root
ROCKET_ADDRESS=127.0.0.1
ROCKET_PORT=8000
